{
  "version": 2,
  "name": "learn-rights-web",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "outputDirectory": "dist" }
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "EXPO_UNSAFE_IGNORE_WEB_DEPENDENCY_CHECKS": "1"
  }
}
