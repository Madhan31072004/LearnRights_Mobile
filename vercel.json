{
  "version": 2,
  "name": "learn-rights-all-in-one",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "frontend/dist" }
    },
    {
      "src": "backend/app/main.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "backend/app/main.py" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "EXPO_UNSAFE_IGNORE_WEB_DEPENDENCY_CHECKS": "1",
    "PYTHONPATH": "backend"
  }
}
